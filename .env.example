# Neuro Apice - Variáveis de ambiente
# Copie para .env.local e ajuste os valores.

# Supabase (backend) - API e Auth
# Produção (self-hosted): https://dados.jbapex.com.br
# Frontend será servido em: https://neuro.jbapex.com.br
VITE_SUPABASE_URL=https://dados.jbapex.com.br
VITE_SUPABASE_ANON_KEY=sua_chave_anon_supabase

# Opcional: chaves para IA (OpenAI, Google AI)
# VITE_OPENAI_API_KEY=sk-proj-your_openai_api_key_here
# VITE_GOOGLE_AI_API_KEY=

# Landing de vendas /fundador (neuro.jbapex.com.br/fundador)
# VSL: só o ID do vídeo no YouTube (ex.: dQw4w9WgXcQ) ou URL completa de embed
# VITE_FUNDADOR_VSL_YOUTUBE_ID=
# Checkout (Kiwify ou outro) — um link por plano
# VITE_FUNDADOR_CHECKOUT_STANDARD_MENSAL=
# VITE_FUNDADOR_CHECKOUT_PRO_MENSAL=
# VITE_FUNDADOR_CHECKOUT_STANDARD_ANUAL=
# VITE_FUNDADOR_CHECKOUT_PRO_ANUAL=

# Meta Pixel (Facebook) — fallback se o ID não estiver guardado em Super Admin → AI Settings → Branding
# VITE_META_PIXEL_ID=123456789012345
